# ================================================================
# Just Ask — Environment Configuration Template
# ================================================================
# Copy this file to .env and customize for your environment.
# DO NOT commit .env to version control.
# ================================================================

# -- Application --
ENV=development                    # development | production | testing
DEBUG=true                         # Enable debug mode (disable in production)
APP_NAME=Just Ask
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -- Logging --
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=pretty                  # pretty | json (use json in production)
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# -- PDF Processing --
PDF_CHUNK_SIZE=1000                # Characters per chunk (min 100)
PDF_CHUNK_OVERLAP=200              # Overlap between chunks (must be < chunk_size)
PDF_MIN_CHUNK_LENGTH=50            # Minimum chunk length (min 10)
PDF_MAX_FILE_SIZE_MB=50            # Maximum upload size in MB

# -- Embedding Service --
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu               # cpu | cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true
EMBEDDING_CACHE_MAX_SIZE=10000     # Max entries in embedding LRU cache

# -- Vector Database (ChromaDB) --
VECTOR_DB_COLLECTION_NAME=documents
VECTOR_DB_DISTANCE_METRIC=cosine   # cosine | l2 | ip

# -- Search --
SEARCH_TOP_K=5                     # Default number of results
HYBRID_SEARCH_VECTOR_WEIGHT=0.7    # 0.0 = BM25 only, 1.0 = vector only

# -- LLM (Groq — Free blazing-fast inference) --
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile  # Options: llama-3.3-70b-versatile, mixtral-8x7b-32768
LLM_TIMEOUT=120                    # Seconds
LLM_TEMPERATURE=0.1                # 0.0 = deterministic, 2.0 = creative
LLM_MAX_TOKENS=2048
LLM_MAX_RETRIES=3

# -- Database --
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./justask.db
# Production (PostgreSQL) — set via Render environment:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/justask
DB_ECHO=false                      # Echo SQL queries (true for debugging)

# -- Security --
MAX_QUERY_LENGTH=2000              # Max characters in a query
RATE_LIMIT_REQUESTS=60             # Requests per minute
